# Bitaxe IP address or hostname (required)
BITAXE_IP=192.168.1.100
# Optional: Separate hostname (defaults to BITAXE_IP if not set)
# BITAXE_HOSTNAME=bitaxe.local

# CORE_VOLTAGE=1245
# MAX_FREQ=924.5
# LOW_STEP_ANALYSE_RANGE=50
# LOW_STEP_WARNING_THRESHOLD=-10

# Server port (default: 3000)
PORT=3000

# Max history entries (~2 days at 1/sec = 172800)
HISTORY_LIMIT=172800

